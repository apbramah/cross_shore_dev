[Unit]
Description=HydraVision Boot Splash Lock
DefaultDependencies=no
After=local-fs.target
Before=getty@tty1.service kiosk.service

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/bin/sh -c 'setterm --cursor off --blank 0 --powersave off --powerdown 0 < /dev/tty1 > /dev/tty1 2>/dev/null || true'
ExecStart=/bin/sh -c 'echo 0 > /sys/class/graphics/fbcon/cursor_blink 2>/dev/null || true'

[Install]
WantedBy=multi-user.target
