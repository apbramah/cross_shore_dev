# HydraVision kiosk local configuration
# Install path: /etc/default/hydravision-kiosk
#
# Set a strong secret for local unlock. Keep file mode 600 on device.
HYDRAVISION_ADMIN_UNLOCK_PASSWORD=CHANGE_ME
HYDRAVISION_KIOSK_MODE=desktop

# Optional overrides:
# HYDRAVISION_UI_URL=file:///home/admin/Dev/cross_shore_dev/apps/controller/mvp_ui_3.html
# HYDRAVISION_WS_HOST=127.0.0.1
# HYDRAVISION_WS_FAST_PORT=8765
# HYDRAVISION_WS_SLOW_PORT=8766
# HYDRAVISION_WS_WAIT_SECONDS=8
# HYDRAVISION_SPLASH_IMAGE=/usr/share/hydravision/hydravision_boot.png
# HYDRAVISION_SPLASH_HANDOFF_TIMEOUT_SECONDS=20
# HYDRAVISION_SPLASH_HANDOFF_POLL_SECONDS=0.2
# HYDRAVISION_SPLASH_HANDOFF_MIN_SECONDS=0.8
# HYDRAVISION_OUTPUT_NAME=DSI-2
# HYDRAVISION_OUTPUT_TRANSFORM=90
# HYDRAVISION_BOOT_DISPLAY_ROTATE=1
